source $HOME/.keychain/$(hostname)-sh

if [[ -L "$HOME/.zshrc" ]]; then
  export SETUP_DIR="$(cd "$(dirname "$(readlink -f "$HOME/.zshrc")")" && cd ../.. && pwd)"
else
  export SETUP_DIR="$HOME/projects/.setup"
fi

if [[ -f "$SETUP_DIR/.setup_env" ]]; then
  export ENV="$(cat "$SETUP_DIR/.setup_env")"
else
  export ENV="personal"
fi


if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

ZINIT_HOME="${XDG_CACHE_HOME:-${HOME}/.local/share}/zinit/zinit.git"
ZINIT_PLUGINS="${XDG_CACHE_HOME:-${HOME}/.local/share}/zinit/plugins"
FZF_HOME="${HOME}/.fzf}"

if [ ! -d "$ZINIT_HOME" ]; then
  mkdir -p "$(dirname $ZINIT_HOME)"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

source "${ZINIT_HOME}/zinit.zsh"

# Add Powerlevel10k
zinit ice depth=1; zinit light romkatv/powerlevel10k

# Add zsh plugins
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab
source "$ZINIT_PLUGINS"/Aloxaf---fzf-tab/fzf-tab.plugin.zsh


# Use arrow keys to cycle through autosuggestions history
bindkey "^[[1;5A" history-beginning-search-backward
bindkey "^[[1;5B" history-beginning-search-forward


HISTFILE=~/.zsh_history
HISTSIZE=1000000
SAVEHIST=1000000
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

unsetopt beep

# Completions case insensitive
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:*' fzf-preview 'ls --color $realpath'
zstyle ':completion:*' completer _complete _ignored _approximate
zstyle ':completion:*' complete true

alias cd="z"
alias l="eza"
alias ls="eza"
alias lt="eza --tree --level"
alias ll="ls -la"
alias hs="history | grep -i"
alias mi=micro

alias k=kubecolor
alias kgp="kubecolor get pods -A"
#alias t=talosctl
alias k9=k9s
alias kc=kubectx
alias kn=kubens
alias tf=terraform
alias f=flux
alias c=clusterctl
alias f9=flux9s
alias mu="mise use --global"

alias gs="git status"
alias gc="git commit"
alias ga="git add"
alias gp="git push"
alias gdf="git diff"

export "MICRO_TRUECOLOR=1"

awsp() {
  local profile
  profile=$(sed -n 's/\[profile \(.*\)\]/\1/gp' ~/.aws/config | fzf)
  if [[ -n "$profile" ]]; then
    export AWS_PROFILE="$profile"
    echo "Switched to AWS profile: $AWS_PROFILE"
  fi
}

awsr() {
  local region
  region=$(aws ec2 describe-regions --query 'Regions[].RegionName' --output text | tr '\t' '\n' | sort | fzf)
  if [[ -n "$region" ]]; then
    export AWS_DEFAULT_REGION="$region"
    echo "Switched to AWS region: $AWS_DEFAULT_REGION"
  fi
}

azp() {
  local selection sub_id
  selection=$(az account list --output json | jq -r '.[] | "\(.name) (\(.id))"' | fzf --height 40% --reverse)
  if [[ -n "$selection" ]]; then
    sub_id=$(echo "$selection" | sed -n 's/.*(\(.*\)).*/\1/p')
    if az account set --subscription "$sub_id"; then
      export AZURE_SUBSCRIPTION_ID="$sub_id"
      echo "Switched to: $(az account show --query name -o tsv)"
    else
      echo "Failed to switch subscription"
    fi
  fi
}

azr() {
  local location
  location=$(az account list-locations --query '[].name' -o tsv | sort | fzf)
  if [[ -n "$location" ]]; then
    az configure --defaults location="$location"
    echo "Switched to Azure region: $location"
  fi
}

# Load completions
autoload bashcompinit && bashcompinit
autoload -Uz compinit && compinit

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
eval "$(mise activate zsh)"
eval "$(zoxide init zsh)"
eval "$(fzf --zsh)"
source <(kubectl completion zsh)
source <(kubecolor completion zsh)
source <(flux completion zsh)
source <(clusterctl completion zsh)

# AWS CLI completion (bash completion loaded via bashcompinit)
if command -v aws_completer >/dev/null 2>&1; then
  complete -C aws_completer aws
fi

# Azure CLI completion (bash script loaded in zsh via bashcompinit)
if [[ -r /etc/bash_completion.d/azure-cli ]]; then
  source /etc/bash_completion.d/azure-cli
fi

# Completions for k as kubecolor
compdef kubecolor=kubectl
compdef k=kubectl

export EDITOR=micro

# Link gitconfig and profile-specific gitconfig
ln -sf "$SETUP_DIR/configs/base/gitconfig" "$HOME/.gitconfig"
ln -sf "$SETUP_DIR/configs/$ENV/gitconfig-profile" "$HOME/.gitconfig-profile"

# this is my default, will be overridden by work zshrc
export KUBECONFIG=$(grep -rl '^kind: Config' ${HOME}/.kube/config ${HOME}/.kube/my_configs/ | tr '\n' ':')

source "$SETUP_DIR/configs/$ENV/zshrc"

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
[[ ! -f "$SETUP_DIR/configs/base/p10k.local.zsh" ]] || source "$SETUP_DIR/configs/base/p10k.local.zsh"
